  "database_design": {
    "engine": "SQLite",
    "orm": "SQLAlchemy 2.0 ORM",
    "migration_tool": "手动 SQL 迁移脚本（migrations/ 目录），按序号执行",
    "tables": {
      "users": {
        "description": "系统用户表，存储登录凭证和角色信息",
        "columns": {
          "id": { "type": "INTEGER", "constraints": "PRIMARY KEY AUTOINCREMENT" },
          "username": { "type": "TEXT", "constraints": "UNIQUE NOT NULL", "example": "admin" },
          "password_hash": { "type": "TEXT", "constraints": "NOT NULL", "example": "$2b$12$..." },
          "display_name": { "type": "TEXT", "constraints": "NOT NULL", "example": "管理员" },
          "role": { "type": "TEXT", "constraints": "NOT NULL CHECK(role IN ('admin','user'))", "default": "user" },
          "is_active": { "type": "INTEGER", "constraints": "NOT NULL DEFAULT 1", "description": "1=启用, 0=禁用" },
          "created_at": { "type": "TEXT", "constraints": "NOT NULL DEFAULT (datetime('now'))" },
          "updated_at": { "type": "TEXT", "constraints": "NOT NULL DEFAULT (datetime('now'))" }
        },
        "indexes": ["username UNIQUE"],
        "seed_data": [
          { "username": "admin", "password": "admin123", "display_name": "管理员", "role": "admin", "is_active": 1 },
          { "username": "user", "password": "user123", "display_name": "普通用户", "role": "user", "is_active": 1 }
        ]
      },

      "contracts": {
        "description": "合同主表，存储合同元数据和内容",
        "columns": {
          "id": { "type": "INTEGER", "constraints": "PRIMARY KEY AUTOINCREMENT" },
          "title": { "type": "TEXT", "constraints": "NOT NULL", "example": "2026年度采购合同" },
          "contract_no": { "type": "TEXT", "constraints": "UNIQUE NOT NULL", "example": "HT-2026-001" },
          "parties": { "type": "TEXT", "constraints": "NOT NULL", "description": "JSON 数组存储签约方名称，如 [\"甲方公司\",\"乙方公司\"]" },
          "amount": { "type": "REAL", "constraints": "NOT NULL", "example": 150000.00 },
          "status": {
            "type": "TEXT",
            "constraints": "NOT NULL DEFAULT 'draft' CHECK(status IN ('draft','pending_review','active','expired','terminated'))",
            "description": "合同状态，流转规则见 status_transitions"
          },
          "sign_date": { "type": "TEXT", "constraints": "", "description": "签订日期，ISO 8601 格式" },
          "expiry_date": { "type": "TEXT", "constraints": "", "description": "到期日期，ISO 8601 格式" },
          "content": { "type": "TEXT", "constraints": "", "description": "合同正文/条款内容" },
          "created_by": { "type": "INTEGER", "constraints": "NOT NULL REFERENCES users(id)" },
          "created_at": { "type": "TEXT", "constraints": "NOT NULL DEFAULT (datetime('now'))" },
          "updated_at": { "type": "TEXT", "constraints": "NOT NULL DEFAULT (datetime('now'))" }
        },
        "indexes": ["contract_no UNIQUE", "status", "created_by"],
        "status_transitions": {
          "description": "合法状态流转映射",
          "draft": ["pending_review", "terminated"],
          "pending_review": ["active", "draft"],
          "active": ["expired", "terminated"],
          "expired": [],
          "terminated": []
        }
      },

      "attachments": {
        "description": "合同附件表，记录上传文件元数据",
        "columns": {
          "id": { "type": "INTEGER", "constraints": "PRIMARY KEY AUTOINCREMENT" },
          "contract_id": { "type": "INTEGER", "constraints": "NOT NULL REFERENCES contracts(id) ON DELETE CASCADE" },
          "filename": { "type": "TEXT", "constraints": "NOT NULL", "description": "存储文件名（UUID 重命名）" },
          "original_name": { "type": "TEXT", "constraints": "NOT NULL", "description": "用户上传时的原始文件名" },
          "file_size": { "type": "INTEGER", "constraints": "NOT NULL", "description": "文件大小（字节），最大 10MB" },
          "mime_type": { "type": "TEXT", "constraints": "NOT NULL", "description": "MIME 类型，如 application/pdf" },
          "uploaded_by": { "type": "INTEGER", "constraints": "NOT NULL REFERENCES users(id)" },
          "created_at": { "type": "TEXT", "constraints": "NOT NULL DEFAULT (datetime('now'))" }
        },
        "indexes": ["contract_id"],
        "allowed_mime_types": [
          "application/pdf",
          "application/msword",
          "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
        ],
        "allowed_extensions": [".pdf", ".doc", ".docx"],
        "max_size_bytes": 10485760
      },

      "audit_logs": {
        "description": "审计日志表，记录所有关键操作",
        "columns": {
          "id": { "type": "INTEGER", "constraints": "PRIMARY KEY AUTOINCREMENT" },
          "user_id": { "type": "INTEGER", "constraints": "NOT NULL REFERENCES users(id)" },
          "action": { "type": "TEXT", "constraints": "NOT NULL", "example": "contract_create" },
          "target_type": { "type": "TEXT", "constraints": "", "description": "操作目标类型：user/contract/attachment" },
          "target_id": { "type": "INTEGER", "constraints": "", "description": "操作目标 ID" },
          "detail": { "type": "TEXT", "constraints": "", "description": "JSON 格式的操作详情" },
          "ip_address": { "type": "TEXT", "constraints": "", "description": "客户端 IP" },
          "created_at": { "type": "TEXT", "constraints": "NOT NULL DEFAULT (datetime('now'))" }
        },
        "indexes": ["user_id", "action", "created_at"],
        "tracked_actions": [
          "login", "logout", "password_change",
          "user_create", "user_update", "user_toggle_status",
          "contract_create", "contract_update", "contract_delete",
          "contract_status_change",
          "attachment_upload", "attachment_delete"
        ]
      }
    }
  },

  "api_design": {
    "base_prefix": "/projects/contract-mgmt/api",
    "content_type": "application/json（文件上传使用 multipart/form-data）",
    "authentication": "Session Cookie（登录后由服务器设置 HTTP-only session cookie）",
    "endpoints": {
      "auth": {
        "prefix": "/projects/contract-mgmt/api/auth",
        "routes": [
          {
            "method": "POST",
            "path": "/login",
            "summary": "用户登录",
            "auth_required": false,
            "request_body": {
              "username": "string, 必填",
              "password": "string, 必填"
            },
            "response_200": {
              "user": { "id": 1, "username": "admin", "display_name": "管理员", "role": "admin" },
              "message": "登录成功"
            },
            "response_401": { "detail": "用户名或密码错误" },
            "response_403": { "detail": "账号已被禁用" }
          },
          {
            "method": "POST",
            "path": "/logout",
            "summary": "用户登出",
            "auth_required": true,
            "response_200": { "message": "已登出" }
          },
          {
            "method": "GET",
            "path": "/me",
            "summary": "获取当前登录用户信息",
            "auth_required": true,
            "response_200": {
              "id": 1, "username": "admin", "display_name": "管理员", "role": "admin", "is_active": true
            }
          }
        ]
      },

      "users": {
        "prefix": "/projects/contract-mgmt/api/users",
        "description": "用户管理（admin 角色可访问 CRUD；所有用户可修改自己密码）",
        "routes": [
          {
            "method": "GET",
            "path": "/",
            "summary": "用户列表",
            "auth_required": true,
            "roles": ["admin"],
            "response_200": {
              "users": [
                { "id": 1, "username": "admin", "display_name": "管理员", "role": "admin", "is_active": true, "created_at": "..." }
              ]
            }
          },
          {
            "method": "POST",
            "path": "/",
            "summary": "创建用户",
            "auth_required": true,
            "roles": ["admin"],
            "request_body": {
              "username": "string, 必填, 3-50字符",
              "password": "string, 必填, 最少6字符",
              "display_name": "string, 必填",
              "role": "string, 必填, enum: admin|user"
            },
            "response_201": { "id": 3, "username": "newuser", "display_name": "新用户", "role": "user", "is_active": true },
            "response_409": { "detail": "用户名已存在" }
          },
          {
            "method": "GET",
            "path": "/{user_id}",
            "summary": "获取单个用户",
            "auth_required": true,
            "roles": ["admin"],
            "response_200": { "id": 1, "username": "admin", "display_name": "管理员", "role": "admin", "is_active": true },
            "response_404": { "detail": "用户不存在" }
          },
          {
            "method": "PUT",
            "path": "/{user_id}",
            "summary": "编辑用户信息",
            "auth_required": true,
            "roles": ["admin"],
            "request_body": {
              "display_name": "string, 可选",
              "role": "string, 可选, enum: admin|user"
            },
            "response_200": { "id": 1, "username": "admin", "display_name": "新名称", "role": "admin", "is_active": true }
          },
          {
            "method": "PUT",
            "path": "/{user_id}/status",
            "summary": "切换用户启用/禁用状态",
            "auth_required": true,
            "roles": ["admin"],
            "request_body": { "is_active": "boolean, 必填" },
            "response_200": { "id": 1, "is_active": false, "message": "用户已禁用" }
          },
          {
            "method": "PUT",
            "path": "/me/password",
            "summary": "修改自己的密码",
            "auth_required": true,
            "roles": ["admin", "user"],
            "request_body": {
              "current_password": "string, 必填",
              "new_password": "string, 必填, 最少6字符"
            },
            "response_200": { "message": "密码修改成功" },
            "response_400": { "detail": "当前密码错误" }
          }
        ]
      },

      "contracts": {
        "prefix": "/projects/contract-mgmt/api/contracts",
        "description": "合同 CRUD + 状态流转",
        "routes": [
          {
            "method": "GET",
            "path": "/",
            "summary": "合同列表（搜索、筛选、分页）",
            "auth_required": true,
            "roles": ["admin", "user"],
            "query_params": {
              "search": "string, 可选, 模糊匹配 title 和 contract_no",
              "status": "string, 可选, 按状态筛选",
              "page": "integer, 默认 1",
              "page_size": "integer, 默认 20, 最大 100"
            },
            "response_200": {
              "contracts": [
                {
                  "id": 1, "title": "采购合同", "contract_no": "HT-2026-001",
                  "parties": ["甲方", "乙方"], "amount": 150000.0, "status": "draft",
                  "sign_date": null, "expiry_date": null,
                  "created_by": 1, "created_at": "...", "updated_at": "..."
                }
              ],
              "total": 42, "page": 1, "page_size": 20
            }
          },
          {
            "method": "POST",
            "path": "/",
            "summary": "创建合同",
            "auth_required": true,
            "roles": ["admin", "user"],
            "request_body": {
              "title": "string, 必填",
              "contract_no": "string, 必填, 唯一",
              "parties": ["string 数组, 必填, 至少2个签约方"],
              "amount": "number, 必填, >=0",
              "sign_date": "string, 可选, ISO 8601 日期",
              "expiry_date": "string, 可选, ISO 8601 日期",
              "content": "string, 可选"
            },
            "response_201": {
              "id": 1, "title": "...", "contract_no": "...", "status": "draft",
              "parties": ["..."], "amount": 150000.0,
              "sign_date": null, "expiry_date": null, "content": null,
              "created_by": 1, "created_at": "...", "updated_at": "..."
            },
            "response_409": { "detail": "合同编号已存在" }
          },
          {
            "method": "GET",
            "path": "/{contract_id}",
            "summary": "合同详情（含附件列表）",
            "auth_required": true,
            "roles": ["admin", "user"],
            "response_200": {
              "id": 1, "title": "...", "contract_no": "...", "status": "draft",
              "parties": ["..."], "amount": 150000.0,
              "sign_date": null, "expiry_date": null, "content": "...",
              "created_by": 1, "created_by_name": "admin",
              "created_at": "...", "updated_at": "...",
              "attachments": [
                { "id": 1, "original_name": "合同附件.pdf", "file_size": 204800, "mime_type": "application/pdf", "uploaded_by": 1, "created_at": "..." }
              ],
              "allowed_transitions": ["pending_review", "terminated"]
            },
            "response_404": { "detail": "合同不存在" }
          },
          {
            "method": "PUT",
            "path": "/{contract_id}",
            "summary": "编辑合同（仅 draft 和 pending_review 状态可编辑核心字段）",
            "auth_required": true,
            "roles": ["admin", "user"],
            "request_body": {
              "title": "string, 可选",
              "parties": ["string 数组, 可选"],
              "amount": "number, 可选, >=0",
              "sign_date": "string, 可选",
              "expiry_date": "string, 可选",
              "content": "string, 可选"
            },
            "response_200": { "...": "更新后的合同对象" },
            "response_400": { "detail": "当前状态不允许编辑" }
          },
          {
            "method": "DELETE",
            "path": "/{contract_id}",
            "summary": "删除合同（仅 admin 可执行，或创建者在 draft 状态可删除）",
            "auth_required": true,
            "roles": ["admin", "user"],
            "response_200": { "message": "合同已删除" },
            "response_403": { "detail": "无权删除此合同" }
          },
          {
            "method": "POST",
            "path": "/{contract_id}/status",
            "summary": "变更合同状态",
            "auth_required": true,
            "roles": ["admin", "user"],
            "request_body": {
              "status": "string, 必填, 目标状态",
              "comment": "string, 可选, 状态变更备注"
            },
            "response_200": {
              "id": 1, "status": "pending_review",
              "previous_status": "draft",
              "message": "状态已更新为 pending_review"
            },
            "response_400": { "detail": "不允许从 draft 变更为 expired" },
            "valid_transitions": {
              "draft": ["pending_review", "terminated"],
              "pending_review": ["active", "draft"],
              "active": ["expired", "terminated"],
              "expired": [],
              "terminated": []
            }
          }
        ]
      },

      "attachments": {
        "prefix": "/projects/contract-mgmt/api",
        "description": "附件上传/下载/删除",
        "routes": [
          {
            "method": "POST",
            "path": "/contracts/{contract_id}/attachments",
            "summary": "上传附件",
            "auth_required": true,
            "roles": ["admin", "user"],
            "content_type": "multipart/form-data",
            "request_body": {
              "file": "binary, 必填, 文件（pdf/doc/docx），≤10MB"
            },
            "response_201": {
              "id": 1, "contract_id": 1, "original_name": "合同附件.pdf",
              "file_size": 204800, "mime_type": "application/pdf",
              "uploaded_by": 1, "created_at": "..."
            },
            "response_400": {
              "type_invalid": { "detail": "不支持的文件类型，仅允许 PDF、DOC、DOCX" },
              "size_exceeded": { "detail": "文件大小超过 10MB 限制" }
            },
            "response_404": { "detail": "合同不存在" }
          },
          {
            "method": "GET",
            "path": "/attachments/{attachment_id}/download",
            "summary": "下载附件",
            "auth_required": true,
            "roles": ["admin", "user"],
            "response_200": "文件流，Content-Disposition: attachment",
            "response_404": { "detail": "附件不存在" }
          },
          {
            "method": "DELETE",
            "path": "/attachments/{attachment_id}",
            "summary": "删除附件",
            "auth_required": true,
            "roles": ["admin", "user"],
            "response_200": { "message": "附件已删除" },
            "response_404": { "detail": "附件不存在" }
          }
        ]
      }
    }
  },

  "frontend_pages": {
    "render_engine": "Jinja2 (FastAPI 内置 Jinja2Templates)",
    "base_template": "base.html（导航栏、flash 消息、CSS/JS 引用、用户信息展示）",
    "version_token": "?v=0.0.1（所有静态资源 URL 携带版本令牌）",
    "cache_control": "所有 HTML 页面由服务器中间件设置 Cache-Control: no-cache 响应头",
    "pages": [
      {
        "route": "GET /projects/contract-mgmt/login",
        "template": "login.html",
        "auth_required": false,
        "description": "登录页面：用户名+密码表单，提交到 POST /api/auth/login。登录成功跳转 /contracts",
        "ui_elements": ["用户名输入框", "密码输入框", "登录按钮", "错误提示区域"]
      },
      {
        "route": "GET /projects/contract-mgmt/users",
        "template": "users/list.html",
        "auth_required": true,
        "roles": ["admin"],
        "description": "用户列表页：表格展示所有用户，支持创建新用户、编辑、启用/禁用操作",
        "ui_elements": ["用户表格（用户名、显示名、角色、状态、创建时间）", "创建用户按钮", "编辑按钮", "启用/禁用切换按钮"]
      },
      {
        "route": "GET /projects/contract-mgmt/users/new",
        "template": "users/form.html",
        "auth_required": true,
        "roles": ["admin"],
        "description": "创建用户表单页",
        "ui_elements": ["用户名输入框", "显示名输入框", "密码输入框", "角色下拉选择", "提交按钮"]
      },
      {
        "route": "GET /projects/contract-mgmt/users/{id}/edit",
        "template": "users/form.html",
        "auth_required": true,
        "roles": ["admin"],
