      { "condition": "无权限操作（非 admin 访问 /users）", "action": "返回 403 页面" },
      { "condition": "API 返回 401", "action": "前端拦截，跳转登录页" }
    ]
  },

  "authentication_scheme": {
    "method": "基于 Session 的服务端认证",
    "session_store": "内存字典（开发阶段）/ 后续可扩展为 Redis 或数据库 session 表",
    "password_hashing": "bcrypt（passlib[bcrypt] 库）",
    "cookie": {
      "name": "session_id",
      "attributes": {
        "httponly": true,
        "samesite": "lax",
        "secure": false,
        "path": "/projects/contract-mgmt/"
      }
    },
    "session_ttl": "24 小时（无操作过期）",
    "middleware": "FastAPI 中间件：从 Cookie 获取 session_id → 查找 session → 注入 request.state.current_user",
    "login_flow": [
      "客户端 POST /api/auth/login 提交 username + password",
      "服务端查询用户 → 校验 bcrypt hash → 校验 is_active",
      "生成随机 session_id（uuid4）→ 存入内存 session_store",
      "Set-Cookie: session_id=<uuid>; HttpOnly; Path=/projects/contract-mgmt/",
      "返回用户信息 JSON"
    ],
    "logout_flow": [
      "客户端 POST /api/auth/logout",
      "服务端从 session_store 移除 session_id",
      "Set-Cookie: session_id=; Max-Age=0（清除 Cookie）"
    ],
    "authorization": [
      "api_routes: 从 request.state.current_user 读取角色，按路由定义的 roles 列表校验",
      "page_routes: 同 API 路由校验，未登录重定向，无权限返回 403",
      "API 端点中通过 Depends(get_current_active_user) 获取当前用户对象"
    ]
  },

  "attachment_storage_scheme": {
    "storage_type": "本地文件系统",
    "storage_path": "uploads/（项目根目录下，可通过配置覆盖）",
    "filename_strategy": "UUID4 + 保留原始扩展名，例如 a1b2c3d4-....pdf",
    "upload_flow": [
      "前端通过 multipart/form-data 提交文件",
      "后端校验 MIME 类型（application/pdf / application/msword / application/vnd.openxmlformats-officedocument.wordprocessingml.document）",
      "后端校验文件扩展名（.pdf / .doc / .docx）",
      "后端校验文件大小（≤ 10MB = 10,485,760 bytes）",
      "生成 UUID 文件名，写入 uploads/ 目录",
      "在 attachments 表写入元数据记录",
      "写入审计日志"
    ],
    "download_flow": [
      "GET /api/attachments/{id}/download",
      "从数据库查询附件记录 → 校验权限（所属合同可见）",
      "设置 Content-Disposition: attachment; filename=\"原始文件名\"",
      "返回 FileResponse 流"
    ],
    "security": [
      "uploads/ 目录不通过静态文件服务暴露",
      "仅通过 /api/attachments/{id}/download 端点下载",
      "须登录后才能访问下载端点",
      ".gitignore 排除 uploads/*（保留 .gitkeep）"
    ]
  },

  "key_technical_decisions": [
    {
      "decision": "SQLite 作为数据库",
      "reasoning": [
        "零配置、零依赖，适合演示和单机部署",
        "文件存储，备份简单（直接复制 .db 文件）",
        "SQLAlchemy ORM 完全兼容，后续可无缝切换到 PostgreSQL",
        "本次迭代范围明确不做多租户/高并发，SQLite 完全够用"
      ],
      "alternatives_considered": [
        { "option": "PostgreSQL", "reason_rejected": "增加运维复杂度，对演示项目过度" },
        { "option": "纯文件/JSON 存储", "reason_rejected": "不支持复杂查询和事务" }
      ]
    },
    {
      "decision": "Jinja2 服务端模板渲染（非 SPA）",
      "reasoning": [
        "技术选型明确指定 Jinja2 + 原生 CSS/JS",
        "无前后端分离的 CORS、构建工具链等额外复杂度",
        "Session Cookie 认证天然适配服务端渲染",
        "页面渲染在服务端完成，首屏加载更快"
      ],
      "alternatives_considered": [
        { "option": "React/Vue SPA + API", "reason_rejected": "需求明确不做，增加构建工具链复杂度" }
      ]
    },
    {
      "decision": "Session 认证（非 JWT）",
      "reasoning": [
        "服务端渲染页面天然适合 Session 认证",
        "无需管理 token 刷新、存储等前端逻辑",
        "HttpOnly Cookie 降低 XSS 风险",
        "登出即时生效（服务端删除 session）"
      ],
      "alternatives_considered": [
        { "option": "JWT Bearer Token", "reason_rejected": "需要前端管理 token 存储和刷新，增加复杂度；对服务端渲染不够友好" }
      ]
    },
    {
      "decision": "bcrypt 密码哈希",
      "reasoning": [
        "行业标准，抗暴力破解",
        "passlib 库提供简洁的 Python API",
        "自动处理 salt 生成和存储"
      ],
      "alternatives_considered": [
        { "option": "SHA-256 + salt", "reason_rejected": "不够安全，容易被 GPU 暴力破解" },
        { "option": "Argon2", "reason_rejected": "passlib 支持但配置更复杂，bcrypt 足够" }
      ]
    },
    {
      "decision": "手动 SQL 迁移脚本（非 Alembic）",
      "reasoning": [
        "SQLite 的 ALTER TABLE 限制多，手动脚本更可控",
        "迁移数量少（仅初始 schema + seed data），自动化工具投入产出比低",
        "脚本按序号命名，执行顺序明确"
      ],
      "alternatives_considered": [
        { "option": "Alembic", "reason_rejected": "SQLite 的 ALTER 限制导致 Alembic 自动生成不可靠" }
      ]
    },
    {
      "decision": "contract_no 由用户输入（非自动生成）",
      "reasoning": [
        "合同编号通常有业务含义和既定规则，自动生成可能不符合实际需求",
        "通过 UNIQUE 约束保证不重复",
        "前端表单提供输入提示和格式建议"
      ]
    },
    {
      "decision": "签约方 parties 存储为 JSON 字符串",
      "reasoning": [
        "签约方数量可变（至少2方），JSON 数组存储灵活",
        "SQLite 支持 JSON 函数（json_extract），后续可做 JSON 查询",
        "避免额外的关联表"
      ],
      "alternatives_considered": [
        { "option": "独立的 party 表 + 关联表", "reason_rejected": "签约方在本系统中不需要独立管理，增加不必要的复杂度" }
      ]
    },
    {
      "decision": "附件仅本地文件系统存储",
      "reasoning": [
        "单机部署，无需对象存储",
        "SQLite 不适合存储大文件（Blob 性能差）",
        "文件系统直接读写效率最高"
      ],
      "alternatives_considered": [
        { "option": "数据库 Blob", "reason_rejected": "SQLite Blob 增大数据库文件，备份恢复慢" },
        { "option": "阿里云 OSS/S3", "reason_rejected": "增加外部依赖和成本，演示项目不需要" }
      ]
    },
    {
      "decision": "FastAPI 中间件统一设置 Cache-Control: no-cache",
      "reasoning": [
        "Hermes 浏览器验收要求 HTML 文档的 HTTP 响应头必须携带 Cache-Control: no-cache",
        "不能用 <meta> 标签代替（浏览器忽略其缓存语义）",
        "编写 ASGI 中间件对 text/html 响应统一添加该头，确保所有页面都满足要求"
      ]
    }
  ],

